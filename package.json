{
  "name": "atomik-planner",
  "version": "1.0.0",
  "description": "Atomic Habits tabanlı kişisel gelişim ve günlük planlama uygulaması",
  "private": true,
  "scripts": {
    "dev": "concurrently \"nodemon --watch server server/index.js\" \"npm --prefix client run dev\"",
    "server": "nodemon server/index.js",
    "client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
