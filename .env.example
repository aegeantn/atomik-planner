# Sunucu portu
PORT=3000

# Yapay zekâ önerileri — OpenRouter (openrouter.ai)
# deepseek/deepseek-v4-flash modeli kullanılır (hızlı + uygun maliyetli)
OPENROUTER_API_KEY=buraya_openrouter_api_key_yaz
# İsteğe bağlı — farklı model denemek için:
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Google Calendar OAuth (Adım 8'de kullanılacak)
# Google Cloud Console > Credentials > Create OAuth Client ID'den alınır
GOOGLE_CLIENT_ID=buraya_client_id_yaz
GOOGLE_CLIENT_SECRET=buraya_client_secret_yaz
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback

# OAuth sonrası yönlendirilecek frontend URL
CLIENT_URL=http://localhost:5173

# Takvim etkinlikleri için saat dilimi
CALENDAR_TIMEZONE=Europe/Istanbul
